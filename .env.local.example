# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the real values.
# SETUP.md explains exactly where to find each one. Never commit .env.local.
# ---------------------------------------------------------------------------

# Supabase — from Project Settings > Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Claude API — from console.anthropic.com. Used by photo → items (Step 3),
# on the SERVER only. Never prefix this with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# Optional: override the vision model. Defaults to claude-sonnet-5 in code.
# ANTHROPIC_MODEL=claude-sonnet-5

# The public URL of the app. Locally this is http://localhost:3000.
# On Vercel, set this to your deployed URL (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: SerpApi key for automatic shopping-list pricing (Google Shopping).
# Server-only, never prefix with NEXT_PUBLIC_. Get a free-tier key at serpapi.com.
# Without it, the shopping list still works — prices are just entered by hand.
SERPAPI_API_KEY=

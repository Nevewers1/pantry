# ---------------------------------------------------------------------------
# Copy this file to ".env.local" and fill in the real values.
# SETUP.md explains exactly where to find each one. Never commit .env.local.
# ---------------------------------------------------------------------------

# Supabase — from Project Settings > Data API / API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Claude API — from console.anthropic.com (used later, in steps 3+, on the server only)
# Safe to leave blank for Step 1. Never prefix this with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=

# The public URL of the app. Locally this is http://localhost:3000.
# On Vercel, set this to your deployed URL (e.g. https://your-app.vercel.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
